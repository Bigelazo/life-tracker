# Neon Postgres connection string (pooled) — create a free project at neon.tech
# Project dashboard → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth.js v5 (Google OAuth)
# AUTH_SECRET is required in every environment — generate one with:
#   openssl rand -base64 32
AUTH_SECRET=""

# AUTH_URL is the public origin of the app (e.g. https://life-tracker.example)
# Used by Auth.js to compute callback URLs. Optional in dev (defaults to the
# request origin), required in production.
AUTH_URL="http://localhost:3000"

# Google OAuth credentials — create an OAuth client in Google Cloud Console:
# APIs & Services → Credentials → Create OAuth client ID (Web application),
# add the configured AUTH_URL + "/api/auth/callback/google" as an authorized
# redirect URI.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Owner allowlist — a single Google account may sign in. Any other Google
# account that attempts sign-in is bounced back to /login with a clear
# message.
OWNER_EMAIL=""

# Test-only sign-in — enables the "Sign in (test owner)" Credentials provider
# and button on /login so Playwright (and local smoke runs) can authenticate
# without real Google OAuth. NEVER set this to "1" in production.
ENABLE_TEST_SIGNIN=""

# GitHub MCP — personal access token with `repo`, `workflow`, and `read:org`
# scopes. Generate one at https://github.com/settings/tokens (classic) or run:
#   gh auth token
# to reuse the token from your `gh` CLI login.
GITHUB_PERSONAL_ACCESS_TOKEN=""
