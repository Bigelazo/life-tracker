{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "set -a; [ -f .env.local ] && . .env.local; exec npx -y @modelcontextprotocol/server-github"
      ],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "set -a; [ -f .env.local ] && . .env.local; exec npx -y @modelcontextprotocol/server-postgres \"$DATABASE_URL\""
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    }
  }
}